{
  "name": "@abelspithost/eslint-config-ts",
  "version": "1.1.1",
  "description": "ESLint configuration preset",
  "homepage": "https://github.com/aspithost/eslint-config-ts#readme",
  "author": {
    "name": "Abel Spithost",
    "url": "https://github.com/aspithost/eslint-config-ts"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aspithost/eslint-config-ts.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && npm run typecheck && tsc -p tsconfig.build.json && npm run deps:check",
    "clean": "rimraf dist",
    "deps:check": "npx -y npm-check-updates --cooldown 2",
    "deps:update": "npx -y npm-check-updates -u --target minor --cooldown 2 && npm install",
    "deps:update:major": "npx -y npm-check-updates -u --cooldown 2 && npm install",
    "lint": "eslint . && npm run publint",
    "publint": "npx -y publint",
    "typecheck": "tsc --noEmit",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.59.3"
  },
  "devDependencies": {
    "@abelspithost/commitlint": "^0.1.0",
    "@abelspithost/tsconfig-node": "^0.0.5",
    "@commitlint/cli": "^21.0.1",
    "@types/node": "^24.12.4",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "eslint": ">=10.0.0",
    "typescript": ">=5.0.0"
  }
}
